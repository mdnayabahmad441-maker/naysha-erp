datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

//////////////////////
// SCHOOL
//////////////////////

model School {
  id   Int    @id @default(autoincrement())
  name String

  subdomain String @unique
  email     String @unique

  plan   String?
  active Boolean @default(false)

  stripeCustomerId     String?
  stripeSubscriptionId String?

  users    User[]
  students Student[]
  teachers Teacher[]
  classes  Class[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////
// USER (NextAuth)
//////////////////////

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  role String @default("ADMIN")

  schoolId Int?
  school   School? @relation(fields: [schoolId], references: [id])

  accounts Account[]
  sessions Session[]

  @@index([schoolId])
}

//////////////////////
// CLASS
//////////////////////

model Class {
  id      Int     @id @default(autoincrement())
  name    String
  section String?

  schoolId Int
  school   School @relation(fields: [schoolId], references: [id])

  students Student[]
  teacher  Teacher?

  attendances  Attendance[]
  feeTemplates FeeTemplate[]

  createdAt DateTime @default(now())

  @@index([schoolId])
}

//////////////////////
// STUDENT
//////////////////////

model Student {
  id         Int     @id @default(autoincrement())
  name       String
  rollNumber String?
  phone      String?
  email      String?
  address    String?

  studentType String @default("DayScholar")

  classId  Int
  schoolId Int

  parentId Int?
  parent   Parent? @relation(fields: [parentId], references: [id])

  class  Class  @relation(fields: [classId], references: [id])
  school School @relation(fields: [schoolId], references: [id])

  attendance Attendance[]
  fees       Fee[]

  @@index([schoolId])
  @@index([classId])
}

//////////////////////
// TEACHER
//////////////////////

model Teacher {
  id    Int     @id @default(autoincrement())
  name  String
  email String?
  phone String?

  schoolId Int
  school   School @relation(fields: [schoolId], references: [id])

  classId Int?   @unique
  class   Class? @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())

  @@index([schoolId])
}

//////////////////////
// ATTENDANCE
//////////////////////

model Attendance {
  id Int @id @default(autoincrement())

  studentId Int
  student   Student @relation(fields: [studentId], references: [id])

  classId Int?
  class   Class? @relation(fields: [classId], references: [id])

  schoolId Int

  date   DateTime
  status String

  @@index([studentId])
  @@index([schoolId])
}

//////////////////////
// FEES
//////////////////////

model Fee {
  id            Int    @id @default(autoincrement())
  invoiceNumber String @unique

  studentId Int
  student   Student @relation(fields: [studentId], references: [id])

  schoolFee    Float @default(0)
  hostelFee    Float @default(0)
  transportFee Float @default(0)
  miscFee      Float @default(0)
  otherCharges Float @default(0)

  totalAmount Float
  paidAmount  Float @default(0)

  status String @default("Unpaid")

  month String?

  dueDate  DateTime
  schoolId Int

  createdAt DateTime @default(now())

  payments Payment[]

  @@index([studentId])
  @@index([schoolId])
}

//////////////////////
// PAYMENTS
//////////////////////

model Payment {
  id        Int      @id @default(autoincrement())
  feeId     Int
  amount    Float
  schoolId  Int
  createdAt DateTime @default(now())

  fee Fee @relation(fields: [feeId], references: [id])

  @@index([feeId])
}

//////////////////////
// FEE TEMPLATE
//////////////////////

model FeeTemplate {
  id Int @id @default(autoincrement())

  classId Int
  class   Class @relation(fields: [classId], references: [id])

  studentType String

  schoolFee    Float @default(0)
  transportFee Float @default(0)
  hostelFee    Float @default(0)
  miscFee      Float @default(0)

  schoolId Int

  @@index([classId])
}

//////////////////////
// PARENT
//////////////////////

model Parent {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  email     String?
  password  String?
  createdAt DateTime @default(now())

  students Student[]
}

//////////////////////
// NEXTAUTH TABLES
//////////////////////

model Account {
  id                String @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
